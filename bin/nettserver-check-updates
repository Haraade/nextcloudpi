#!/bin/bash

# print message if an update is available

VERFILE=/usr/local/etc/nettserver-version 
LATEST=/var/run/.nettserver-latest-version

if ncp-test-updates; then
  echo -e "\nNETTSERVER \e[1m$( cat $VERFILE)\e[0m is outdated"
  echo -e "update to \e[1m$( cat $LATEST )\e[0m through 'nettserver-config' or type 'sudo nettserver-update'" 
else
  echo -e "\nNETTSERVER \e[1m$( cat $VERFILE)\e[0m is up to date"
fi
